# ============================================================
#  ClinicFlow — variables de entorno (plantilla)
#  Copia este archivo a .env y completa los valores.
#  NUNCA subas el .env real al repositorio.
# ============================================================

# ---- Aplicación ----
APP_NAME=ClinicFlow
ENVIRONMENT=development          # development | production
DEBUG=true

# ---- Base de datos ----
# En docker-compose el host es "db"; en local puede ser "localhost".
DATABASE_URL=postgresql+psycopg2://clinicflow:clinicflow@db:5432/clinicflow

# ---- Seguridad / Auth ----
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=

# ---- Modelo de lenguaje (LLM) ----
# Compatible con la API de OpenAI. Por defecto apunta a Groq (gratis, sin tarjeta:
# crea una key en https://console.groq.com). Para usar un modelo local con
# llama.cpp: LLM_BASE_URL=http://llama:8080/v1 y LLM_MODEL=<tu-modelo>.
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
