# ============================================================
#  ClinicFlow — variables de entorno (plantilla)
#  Copia este archivo a .env y completa los valores.
#  NUNCA subas el .env real al repositorio.
# ============================================================

# ---- Aplicación ----
APP_NAME=ClinicFlow
ENVIRONMENT=development          # development | production
DEBUG=true

# ---- Base de datos ----
# En docker-compose el host es "db"; en local puede ser "localhost".
DATABASE_URL=postgresql+psycopg2://clinicflow:clinicflow@db:5432/clinicflow

# ---- Seguridad / Auth ----
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=

# ---- Modelo de lenguaje (LLM) ----
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
